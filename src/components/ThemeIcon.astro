---

---

<button
	id="themeToggle"
	transition:persist
	aria-label="Toggle theme"
	class="fixed top-10 right-10 w-fit rounded-md p-2 transition-colors hover:bg-gray-100 dark:hover:bg-gray-800"
>
	<svg
		width="24"
		height="24"
		viewBox="0 0 24 24"
		fill="none"
		xmlns="http://www.w3.org/2000/svg"
	>
		<path
			class="sun"
			fill-rule="evenodd"
			clip-rule="evenodd"
			d="M12 1.25a.75.75 0 01.75.75v1a.75.75 0 01-1.5 0V2a.75.75 0 01.75-.75zM4.399 4.399a.75.75 0 011.06 0l.707.707a.75.75 0 01-1.06 1.06l-.707-.707a.75.75 0 010-1.06zm15.202 0a.75.75 0 010 1.06l-.707.707a.75.75 0 11-1.06-1.06l.707-.707a.75.75 0 011.06 0zM12 7.25a4.75 4.75 0 100 9.5 4.75 4.75 0 000-9.5zM5.75 12a6.25 6.25 0 1112.5 0 6.25 6.25 0 01-12.5 0zm-4.5 0a.75.75 0 01.75-.75h1a.75.75 0 010 1.5H2a.75.75 0 01-.75-.75zm19 0a.75.75 0 01.75-.75h1a.75.75 0 010 1.5h-1a.75.75 0 01-.75-.75zm-15.084 6.834a.75.75 0 011.06 0l.707.707a.75.75 0 11-1.06 1.06l-.707-.707a.75.75 0 010-1.06zm12.728 0a.75.75 0 010 1.06l-.707.707a.75.75 0 11-1.06-1.06l.707-.707a.75.75 0 011.06 0zM12 20.25a.75.75 0 01.75.75v1a.75.75 0 01-1.5 0v-1a.75.75 0 01.75-.75z"
			fill="currentColor"></path>
		<path
			class="moon"
			fill-rule="evenodd"
			clip-rule="evenodd"
			d="M11.25 2.5a.75.75 0 01.642.917 6.25 6.25 0 008.691 8.691.75.75 0 011.125.827 8.75 8.75 0 11-11.375-11.375.75.75 0 01.917.94z"
			fill="currentColor"></path>
	</svg>
</button>

<style>
	#themeToggle {
		border: 0;
		background: none;
		cursor: pointer;
	}

	.sun {
		fill: black;
	}

	.moon {
		fill: transparent;
	}

	:global(.dark) .sun {
		fill: transparent;
	}

	:global(.dark) .moon {
		fill: white;
	}
</style>

<script is:inline>
	const theme = localStorage.getItem('theme')
		?? (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
	document.documentElement.classList.toggle('dark', theme === 'dark');
	localStorage.setItem('theme', theme);
</script>

<script>
	document.addEventListener('astro:page-load', () => {
		const btn = document.getElementById('themeToggle');
		if (!btn || btn.dataset.listenerAttached) return;
		btn.dataset.listenerAttached = 'true';
		btn.addEventListener('click', () => {
			document.documentElement.classList.toggle('dark');
			localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
		});
	});
</script>
